# tg-bot-krisha — environment variables template
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# Railway: set all variables under service → Variables in the dashboard.
# Local dev: create .env in the project root (loaded automatically by pydantic-settings).

# ── Required ───────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# Supabase project URL  (https://<ref>.supabase.co)
SUPABASE_URL=

# Supabase service_role key — server-side only, NEVER expose to the client
# NOTE for Railway: use the TRANSACTION-MODE POOLER connection, not the direct URL.
#   Pooler host: aws-0-<region>.pooler.supabase.com  port: 6543
#   Direct host: db.<ref>.supabase.co                port: 5432
#   Railway's network is IPv4-only and cannot reach the direct (IPv6) endpoint.
SUPABASE_SERVICE_KEY=

# ── Optional (have defaults) ───────────────────────────────────────────────────

# How often the scraper polls krisha.kz, in seconds (default: 300 = 5 min)
POLL_INTERVAL_SECONDS=300

# httpx request timeout in seconds (default: 20)
REQUEST_TIMEOUT=20

# Base URL for krisha.kz requests (default: https://krisha.kz)
KRISHA_BASE_URL=https://krisha.kz

# Days before seen_listings rows are eligible for TTL cleanup (default: 30)
# See docs/schema.md for the pg_cron cleanup job details.
SEEN_LISTINGS_TTL_DAYS=30

# Redis connection URL — if set, RedisStorage is used for FSM instead of Supabase fsm_state table.
# Leave blank to use SupabaseFSMStorage (default, no Redis dependency needed).
REDIS_URL=

# Webhook mode (production/Railway):
#   Set WEBHOOK_URL to the public HTTPS URL that Telegram will POST updates to.
#   Example: https://<your-railway-service>.railway.app/webhook
#   If blank, the bot starts in polling mode (development).
WEBHOOK_URL=

# aiohttp server port for webhook mode (default: 8080).
# Railway injects $PORT at runtime — set this to match Railway's dynamic PORT.
PORT=8080
